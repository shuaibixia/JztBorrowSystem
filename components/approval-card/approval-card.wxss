:host {
  display: block;
}

.ac {
  padding: 22rpx 24rpx;
  background: var(--surface, #FFFFFF);
}

.ac--pressed {
  background: var(--bg-hover, #EDF1F5);
}

.ac-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2, 16rpx);
}

.ac-eq {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--t0, #1D1D1F);
  font-size: var(--type-label, 14px);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ac-meta {
  display: flex;
  align-items: center;
  gap: var(--space-1, 8rpx);
  min-width: 0;
  margin-top: var(--space-1, 8rpx);
}

.ac-person,
.ac-time,
.ac-purpose {
  overflow: hidden;
  color: var(--t2, #6E6E73);
  font-size: var(--type-meta, 12px);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.ac-person {
  max-width: 220rpx;
}

.ac-dot {
  flex: 0 0 auto;
  color: var(--t3, #86868B);
  font-size: var(--type-meta, 12px);
}

.ac-time {
  flex: 1;
  min-width: 0;
}

.ac-purpose {
  display: block;
  margin-top: var(--space-1, 8rpx);
  color: var(--t1, #424245);
}
