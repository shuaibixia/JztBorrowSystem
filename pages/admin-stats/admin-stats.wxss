.page-container {
  padding-top: var(--space-4);
  padding-bottom: var(--pb);
}

.stats-overview {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin: 0 var(--mx) 32rpx;
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r);
  background: var(--surface);
}

.overview-item {
  min-width: 0;
  padding: 26rpx 8rpx 24rpx;
  text-align: center;
}

.overview-item + .overview-item {
  border-left: 1rpx solid var(--line-soft);
}

.overview-value,
.overview-label {
  display: block;
}

.overview-value {
  overflow: hidden;
  color: var(--t0);
  font-size: 20px;
  font-weight: 600;
  line-height: 1.2;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.overview-label {
  margin-top: 8rpx;
  color: var(--t2);
  font-size: 10px;
}

.overview-item.overdue .overview-value {
  color: var(--err);
}

.stats-tabs {
  display: flex;
  margin: 0 var(--mx) 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.stats-tab {
  flex: 1;
  min-width: 0;
  padding: 0 4rpx 18rpx;
  border-bottom: 4rpx solid transparent;
  color: var(--t2);
  font-size: var(--f3);
  line-height: 1.35;
  text-align: center;
}

.stats-tab.active {
  border-bottom-color: var(--c1);
  color: var(--c1);
  font-weight: 600;
}

.stats-card {
  margin: 0 var(--mx);
  padding: 28rpx 24rpx;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r);
  background: var(--surface);
}

.stats-card-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.stats-card-title {
  color: var(--t0);
  font-size: var(--type-heading);
  font-weight: 600;
}

.stats-card-note {
  flex: 0 0 auto;
  color: var(--t2);
  font-size: var(--f4);
}

.category-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 68rpx;
}

.category-name {
  flex: 0 0 96rpx;
  overflow: hidden;
  color: var(--t1);
  font-size: var(--f3);
  text-align: right;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-track {
  flex: 1;
  height: 14rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: var(--bg-hover);
}

.category-fill {
  min-width: 8rpx;
  height: 100%;
  border-radius: inherit;
  background: var(--c1);
}

.category-count {
  flex: 0 0 42rpx;
  color: var(--t0);
  font-size: var(--f3);
  font-weight: 600;
  text-align: right;
}

.active-member-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 76rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.active-member-row:last-child {
  border-bottom: 0;
}

.member-rank {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: var(--r-control);
  background: var(--bg-hover);
  color: var(--t2);
  font-size: var(--f4);
  font-weight: 600;
}

.member-rank.top {
  background: var(--c1-bg);
  color: var(--c1);
}

.active-member-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--t0);
  font-size: var(--f2);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.active-member-count {
  flex: 0 0 auto;
  color: var(--t2);
  font-size: var(--f3);
}

.trend-legend {
  display: flex;
  gap: 14rpx;
  color: var(--t2);
  font-size: var(--f4);
}

.legend-item {
  display: flex;
  align-items: center;
}

.legend-dot {
  display: inline-block;
  width: 10rpx;
  height: 10rpx;
  margin-right: 4rpx;
  border-radius: 50%;
}

.legend-dot.checkout,
.trend-bar.checkout { background: var(--c1); }
.legend-dot.returns,
.trend-bar.returns { background: var(--t3); }

.trend-chart {
  display: flex;
  align-items: flex-end;
  height: 292rpx;
  padding: 0 4rpx 4rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.trend-column {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  min-width: 0;
  height: 100%;
}

.trend-bars {
  display: flex;
  flex: 1;
  align-items: flex-end;
  justify-content: center;
  gap: 6rpx;
  width: 100%;
  min-height: 16rpx;
}

.trend-bar {
  width: 18rpx;
  min-height: 6rpx;
  border-radius: 6rpx 6rpx 0 0;
}

.trend-label {
  margin-top: 10rpx;
  color: var(--t3);
  font-size: 10px;
}

.stats-empty {
  padding: 36rpx 0 20rpx;
  text-align: center;
}

.state-panel {
  margin: 0 var(--mx);
  padding: var(--state-pad);
  text-align: center;
}
