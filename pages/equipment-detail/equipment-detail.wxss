.detail-page {
  padding: 0 0 var(--pbf);
}

.state-panel {
  margin: 0 var(--mx);
  padding: var(--state-pad);
}

.state-panel.compact {
  padding: var(--state-pad-compact);
}

.equipment-hero {
  position: relative;
  height: 280rpx;
  overflow: hidden;
  background: var(--bg-sec);
}

.hero-image,
.hero-placeholder {
  width: 100%;
  height: 100%;
}

.hero-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--t3);
}

.hero-status {
  position: absolute;
  right: var(--mx);
  bottom: var(--space-2);
}

.detail-sheet {
  min-height: 0;
  padding: var(--space-4) var(--mx) var(--space-5);
  background: var(--bg);
}

.equipment-summary {
  margin-bottom: var(--space-4);
}

.equipment-name,
.equipment-code {
  display: block;
}

.equipment-name {
  overflow: hidden;
  color: var(--t0);
  font-size: var(--type-display);
  font-weight: 600;
  line-height: 1.25;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.equipment-code {
  margin-top: var(--space-1);
  overflow: hidden;
  color: var(--t2);
  font-size: var(--type-meta);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-1);
  margin-top: var(--space-2);
}

.equipment-description {
  display: block;
  margin-top: var(--space-3);
  color: var(--t1);
  font-size: var(--type-label);
  line-height: 1.6;
  word-break: break-all;
}

.tabs-wrap {
  margin: 0 0 var(--space-4);
  border-bottom: 1rpx solid var(--line-soft);
}

.info-section {
  margin-bottom: var(--space-4);
}

.detail-section-title {
  display: block;
  margin-bottom: var(--space-2);
  color: var(--t0);
  font-size: var(--type-heading);
  font-weight: 600;
}

.info-list,
.timeline-list {
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r-content);
  background: var(--surface);
}

.info-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: var(--space-4);
  min-height: 80rpx;
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.info-row:last-child {
  border-bottom: 0;
}

.info-label {
  flex: 0 0 auto;
  color: var(--t2);
  font-size: var(--type-label);
}

.info-value {
  flex: 1;
  min-width: 0;
  color: var(--t0);
  font-size: var(--type-label);
  text-align: right;
  word-break: break-all;
}

.timeline-row {
  display: flex;
  gap: var(--space-2);
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.timeline-row:last-child {
  border-bottom: 0;
}

.timeline-dot {
  flex: 0 0 auto;
  width: 12rpx;
  height: 12rpx;
  margin-top: 8rpx;
  border-radius: var(--r-pill);
  background: var(--c1);
}

.timeline-dot.muted {
  background: var(--warn);
}

.timeline-main {
  flex: 1;
  min-width: 0;
}

.timeline-title,
.timeline-sub {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.timeline-title {
  color: var(--t0);
  font-size: var(--type-label);
  font-weight: 600;
}

.timeline-sub {
  margin-top: var(--space-1);
  color: var(--t2);
  font-size: var(--type-meta);
}

.detail-bottom-bar {
  padding-top: var(--space-2);
}

.minor-actions {
  display: flex;
  justify-content: flex-start;
  flex-wrap: wrap;
  gap: var(--space-1) var(--space-2);
  margin-bottom: var(--space-2);
}

.action-error {
  display: flex;
  align-items: flex-start;
  gap: var(--space-1);
  margin-bottom: var(--space-2);
  padding: var(--error-pad);
  font-size: var(--type-label);
  line-height: 1.5;
}

.action-error text {
  flex: 1;
  min-width: 0;
}

.sheet-content {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  padding: var(--space-3) 0 var(--space-4);
}

.field-label,
.condition-label {
  color: var(--t2);
  font-size: var(--type-label);
}

.condition-label {
  text-align: center;
}
