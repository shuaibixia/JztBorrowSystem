.page-container {
  padding-top: var(--space-4);
  padding-bottom: var(--pb);
}

.notification-context {
  margin: 0 var(--mx) 24rpx;
}

.notification-context-copy {
  display: block;
  overflow: hidden;
  color: var(--t2);
  font-size: var(--f3);
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notification-list {
  margin: 0 var(--mx);
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r);
  background: var(--surface);
}

.notification-card {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  min-height: 112rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.notification-card:last-child {
  border-bottom: 0;
}

.notification-card.is-unread {
  background: rgba(36, 95, 146, 0.045);
}

.notification-icon {
  display: flex;
  flex: 0 0 auto;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  border-radius: var(--r-control);
  background: var(--c1-bg);
  color: var(--c1);
}

.notification-main {
  flex: 1;
  min-width: 0;
}

.notification-head {
  display: flex;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
}

.notification-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--t0);
  font-size: var(--f2);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread-dot {
  flex: 0 0 auto;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--err);
}

.notification-content,
.notification-time {
  display: block;
}

.notification-content {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  color: var(--t1);
  font-size: var(--f3);
  line-height: 1.5;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
}

.notification-time {
  margin-top: 7rpx;
  color: var(--t3);
  font-size: var(--f4);
}

.notification-arrow {
  flex: 0 0 auto;
  margin-top: 14rpx;
  color: var(--t3);
}

.state-panel {
  margin: 0 var(--mx);
  padding: var(--state-pad);
  text-align: center;
}
