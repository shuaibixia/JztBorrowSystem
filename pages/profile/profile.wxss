.profile-page {
  padding-top: 0;
  padding-bottom: var(--tab-page-bottom);
}

.bind-panel {
  margin: 0 var(--mx);
  padding-top: calc(var(--space-6) + env(safe-area-inset-top));
}

.bind-brand {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  margin: var(--space-3) 0 var(--space-4);
}

.bind-brand-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--r-control);
  background: var(--c1-bg);
  color: var(--c1);
}

.bind-title,
.bind-subtitle {
  display: block;
}

.bind-title {
  color: var(--t0);
  font-size: var(--type-heading);
  font-weight: 600;
}

.bind-subtitle {
  margin-top: 4rpx;
  color: var(--t2);
  font-size: var(--type-label);
}

.bind-card {
  padding: var(--space-4);
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r-content);
  background: var(--surface);
}

.bind-label {
  display: block;
  margin-bottom: var(--space-2);
  color: var(--t1);
  font-size: var(--type-label);
  font-weight: 500;
}

.student-id-input {
  height: 88rpx;
  margin-bottom: var(--space-3);
  padding: 0 20rpx;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r-control);
  background: var(--bg-sec);
  color: var(--t0);
  font-size: var(--type-body);
}

.bind-hint {
  display: block;
  margin-top: var(--space-2);
  color: var(--t3);
  font-size: var(--type-meta);
  text-align: center;
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  min-height: 196rpx;
  padding: calc(var(--space-6) + env(safe-area-inset-top)) var(--mx) var(--space-4);
  background: #273038;
  color: #FFFFFF;
}

.profile-avatar {
  flex: 0 0 auto;
  width: 96rpx;
  height: 96rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
  border-radius: var(--r-pill);
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F3F5F7;
  border-color: transparent;
  color: #273038;
  font-size: 30px;
  font-weight: 600;
}

.profile-user {
  display: flex;
  flex: 1;
  flex-direction: column;
  min-width: 0;
}

.profile-name,
.profile-id,
.role-chip {
  display: block;
}

.profile-name {
  overflow: hidden;
  font-size: var(--type-display);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-id {
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: var(--type-meta);
}

.role-chip {
  align-self: flex-start;
  margin-top: var(--space-2);
  padding: 4rpx 10rpx;
  border-radius: var(--r-control);
  background: rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.9);
  font-size: var(--type-meta);
}

.profile-stats-card {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin: var(--space-4) var(--mx) var(--space-5);
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r-content);
  background: var(--surface);
}

.profile-stat {
  min-width: 0;
  padding: 20rpx 8rpx;
  text-align: center;
}

.profile-stat + .profile-stat {
  border-left: 1rpx solid var(--line-soft);
}

.profile-stat-value,
.profile-stat-label {
  display: block;
}

.profile-stat-value {
  overflow: hidden;
  color: var(--t0);
  font-size: var(--type-heading);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-stat-label {
  margin-top: 4rpx;
  color: var(--t2);
  font-size: var(--type-meta);
}

.profile-section {
  margin: 0 var(--mx) var(--space-5);
}

.profile-section-title {
  display: block;
  margin-bottom: var(--space-2);
  color: var(--t0);
  font-size: var(--type-heading);
  font-weight: 600;
}

.profile-menu-card {
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r-content);
  background: var(--surface);
}

.profile-menu-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  min-height: 104rpx;
  padding: 18rpx 20rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.profile-menu-row--pressed {
  background: var(--bg-hover);
}

.profile-menu-row.last {
  border-bottom: 0;
}

.menu-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: var(--r-control);
}

.menu-icon.blue { background: var(--c1-bg); color: var(--c1); }
.menu-icon.orange { background: var(--warn-bg); color: var(--warn); }
.menu-icon.neutral { background: var(--bg-sec); color: var(--t1); }

.menu-copy {
  flex: 1;
  min-width: 0;
}

.menu-title,
.menu-sub {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.menu-title {
  color: var(--t0);
  font-size: var(--type-label);
  font-weight: 600;
}

.menu-sub {
  margin-top: 4rpx;
  color: var(--t2);
  font-size: var(--type-meta);
}

.menu-sub.danger { color: var(--err); }
.menu-arrow { color: var(--t3); }
