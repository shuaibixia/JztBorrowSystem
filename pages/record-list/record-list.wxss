.records-page {
  padding: var(--space-5) var(--mx) var(--tab-page-bottom);
}

.record-filter-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.record-filter-label {
  color: var(--t1);
  font-size: var(--type-label);
  font-weight: 500;
}

.record-filter-count {
  flex: 0 0 auto;
  color: var(--t3);
  font-size: var(--type-meta);
}

.record-tabs-scroll {
  margin-bottom: var(--space-4);
  white-space: nowrap;
}

.record-tabs {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  min-height: 88rpx;
  border-bottom: 1rpx solid var(--line-soft);
}

.record-tab {
  box-sizing: border-box;
  min-width: 0;
  min-height: 88rpx;
  padding: 24rpx 4rpx 16rpx;
  border-bottom: 4rpx solid transparent;
  color: var(--t2);
  font-size: var(--type-label);
  line-height: 1.35;
  text-align: center;
}

.record-tab--active {
  border-bottom-color: var(--c1);
  color: var(--c1);
  font-weight: 600;
}

.record-list {
  margin-top: var(--space-1);
  overflow: hidden;
  border: 1rpx solid var(--line-soft);
  border-radius: var(--r-content);
  background: var(--surface);
}

.record-row {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  min-width: 0;
  min-height: 112rpx;
  padding: 24rpx;
}

.record-row + .record-row {
  border-top: 1rpx solid var(--line-soft);
}

.record-row--pressed {
  background: var(--bg-hover);
}

.record-main {
  flex: 1;
  min-width: 0;
}

.record-head {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  min-width: 0;
}

.record-name {
  flex: 1;
  min-width: 0;
  overflow: hidden;
  color: var(--t0);
  font-size: var(--type-label);
  font-weight: 600;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-time-row {
  display: flex;
  align-items: center;
  gap: 6rpx;
  min-width: 0;
  margin-top: var(--space-2);
  overflow: hidden;
  color: var(--t2);
  font-size: var(--type-meta);
}

.record-time-row text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.record-arrow {
  flex: 0 0 auto;
  color: var(--t3);
}

.state-panel {
  padding: var(--state-pad);
}
